# Primary Gemini API key (required)
GEMINI_API_KEY=

# Fallback keys, tried in order if the primary is rate-limited/exhausted (optional)
GEMINI_API_KEY_FALLBACK_1=
GEMINI_API_KEY_FALLBACK_2=

# Seconds to wait before retrying a key that hit a 429 (optional, default 300 = 5 min)
KEY_COOLDOWN_SECONDS=

# Number of persona excerpts injected per request (optional, default 3 if unset)
RETRIEVAL_TOP_K=
